	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"if (pm.info.requestName === \"Obtain JWT Token\" || !pm.collectionVariables.get(\"testRunId\")) {",
					"    const suffix = Date.now().toString().slice(-8) + Math.floor(Math.random() * 100).toString().padStart(2, \"0\");",
					"    pm.collectionVariables.set(\"testRunId\", suffix);",
					"}",
					"",
					"const runId = pm.collectionVariables.get(\"testRunId\");",
					"pm.collectionVariables.set(\"enquiryId\", `ENQ${runId}`);",
					"pm.collectionVariables.set(\"appointmentId\", `APP${runId}`);",
					"pm.collectionVariables.set(\"feedbackId\", `FB${runId}`);"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"const requestName = pm.info.requestName;",
					"let jsonData = {};",
					"try {",
					"    jsonData = pm.response.json();",
					"} catch (error) {",
					"    jsonData = {};",
					"}",
					"",
					"function expectStatus(codes) {",
					"    pm.test(`${requestName} returns ${codes.join(\" or \")}`, function () {",
					"        pm.expect(codes).to.include(pm.response.code);",
					"    });",
					"}",
					"",
					"function expectObjectKey(key) {",
					"    pm.test(`${requestName} includes ${key}`, function () {",
					"        pm.expect(jsonData).to.have.property(key);",
					"    });",
					"}",
					"",
					"pm.test(`${requestName} has no server error`, function () {",
					"    pm.expect(pm.response.code).to.be.below(500);",
					"});",
					"",
					"switch (requestName) {",
					"    case \"Obtain JWT Token\":",
					"        expectStatus([200]);",
					"        expectObjectKey(\"access\");",
					"        expectObjectKey(\"refresh\");",
					"        pm.environment.set(\"accessToken\", jsonData.access);",
					"        pm.environment.set(\"refreshToken\", jsonData.refresh);",
					"        break;",
					"    case \"Refresh JWT Token\":",
					"        expectStatus([200]);",
					"        expectObjectKey(\"access\");",
					"        pm.environment.set(\"accessToken\", jsonData.access);",
					"        break;",
					"    case \"Health Status\":",
					"        expectStatus([200]);",
					"        pm.test(\"Health response marks chatbot ready\", function () {",
					"            pm.expect(jsonData.status).to.eql(\"ok\");",
					"            pm.expect(jsonData.chatbot_ready).to.be.a(\"boolean\");",
					"            pm.expect(jsonData.llm_enabled).to.be.a(\"boolean\");",
					"        });",
					"        break;",
					"    case \"Suggestions List\":",
					"        expectStatus([200]);",
					"        pm.test(\"Suggestions response has items\", function () {",
					"            pm.expect(jsonData.suggestions).to.be.an(\"array\").that.is.not.empty;",
					"        });",
					"        break;",
					"    case \"Reset History\":",
					"        expectStatus([200]);",
					"        pm.test(\"Reset returns ok\", function () {",
					"            pm.expect(jsonData.status).to.eql(\"ok\");",
					"        });",
					"        break;",
					"    case \"Submit Chat Query\":",
					"        expectStatus([200]);",
					"        pm.test(\"Chat response can be rendered by UI\", function () {",
					"            pm.expect(jsonData.answer).to.be.a(\"string\").and.not.empty;",
					"            pm.expect(jsonData.intent).to.be.a(\"string\").and.not.empty;",
					"            pm.expect(jsonData.elapsed).to.be.a(\"number\");",
					"        });",
					"        break;",
					"    case \"Submit Created Enquiry Chat Query\":",
					"        expectStatus([200]);",
					"        pm.test(\"Chatbot can answer from CRM data created in this run\", function () {",
					"            pm.expect(jsonData.answer).to.include(pm.collectionVariables.get(\"enquiryId\"));",
					"            pm.expect(jsonData.answer).to.include(`Postman QA ${pm.collectionVariables.get(\"testRunId\")}`);",
					"            pm.expect(jsonData.intent).to.be.a(\"string\").and.not.empty;",
					"            pm.expect(jsonData.elapsed).to.be.a(\"number\");",
					"        });",
					"        break;",
					"    case \"Get Enquiries\":",
					"    case \"Get Appointments\":",
					"    case \"Get Feedbacks\":",
					"        expectStatus([200]);",
					"        pm.test(`${requestName} returns an array`, function () {",
					"            pm.expect(jsonData).to.be.an(\"array\");",
					"        });",
					"        break;",
					"    case \"Create Enquiry\":",
					"        expectStatus([201]);",
					"        pm.test(\"Created enquiry uses generated ID\", function () {",
					"            pm.expect(jsonData.enquiry_id).to.eql(pm.collectionVariables.get(\"enquiryId\"));",
					"        });",
					"        break;",
					"    case \"Create Appointment\":",
					"        expectStatus([201]);",
					"        pm.test(\"Created appointment uses generated ID\", function () {",
					"            pm.expect(jsonData.appointment_id).to.eql(pm.collectionVariables.get(\"appointmentId\"));",
					"        });",
					"        break;",
					"    case \"Create Feedback\":",
					"        expectStatus([201]);",
					"        pm.test(\"Created feedback is linked to generated enquiry\", function () {",
					"            pm.expect(jsonData.feedback_id).to.eql(pm.collectionVariables.get(\"feedbackId\"));",
					"            pm.expect(jsonData.enquiry_id).to.eql(pm.collectionVariables.get(\"enquiryId\"));",
					"        });",
					"        break;",
					"}"
				]
			}
		}
	],
