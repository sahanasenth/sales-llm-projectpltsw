# .gitignore
# Prevents sensitive and generated files from being committed to Git.

# ── Environment & Secrets ─────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/

# ── Virtual Environments ──────────────────────────────────────
venv/
env/
.venv/
ENV/

# ── Django ────────────────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
